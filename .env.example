ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CRYPTO_PANIC_API_KEY=
BINANCE_API_KEY=
CACHE_TTL_SECONDS=60

# Paper trading (safe default; no real exchange orders are sent)
PAPER_TRADING_ENABLED=true
PAPER_INITIAL_CASH=10000
PAPER_DB_PATH=data/paper_trading.sqlite3
PREDICTION_DB_PATH=data/prediction_tracking.sqlite3
SHADOW_DB_PATH=data/shadow_portfolios.sqlite3
SHADOW_INITIAL_CASH=10000
SHADOW_POSITION_FRACTION=0.10
SHADOW_FEE_RATE=0.001
SHADOW_SLIPPAGE_RATE=0.0005
MAX_POSITION_FRACTION=0.10
MAX_DRAWDOWN_FRACTION=0.10
MAX_DAILY_LOSS_FRACTION=0.02
MINIMUM_ORDER_QUOTE=10

# Email alerts (SMTP; for Gmail use an app password, not your normal password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
ALERT_EMAIL_TO=

# SMS alerts (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=
